C4Container
    title FTGO — Diagrama de Contenedores (C4 Nivel 2) [v1.1]

    Person(consumidor, "Consumidor", "STK-01 [US-01]")
    Person(restaurante, "Restaurante", "STK-02 [US-02]")
    Person(courier, "Courier", "STK-03 [US-03]")
    Person(backoffice, "Empleado FTGO", "STK-04")

    Container(mobile_app, "Mobile App", "iOS / Android", "Consumidor y courier [FSD UC-01 UC-03 UC-05]")
    Container(web_admin, "Web Admin", "React SPA", "Restaurante y back office [FSD UC-02]")

    Container_Boundary(ftgo, "FTGO Platform") {

        Container(gateway, "API Gateway", "Spring Cloud Gateway", "Strangler + correlation-id [ADR-0001] [NFR-08]")

        Container(consumer_svc, "Consumer Service", "Java / Spring Boot", "C-01 [PRD]")
        ContainerDb(consumer_db, "Consumer DB", "PostgreSQL", "DB-per-service")

        Container(restaurant_svc, "Restaurant Service", "Java / Spring Boot", "C-02 [PRD]")
        ContainerDb(restaurant_db, "Restaurant DB", "PostgreSQL", "DB-per-service")

        Container(order_svc, "Order Service", "Java / Spring Boot", "C-03; dueño aggregate Order [NFR-07] [ADR-0002]")
        ContainerDb(order_db, "Order DB", "PostgreSQL", "DB-per-service")

        Container(kitchen_svc, "Kitchen Service", "Java / Spring Boot", "C-04 cocina [FSD UC-02]")
        ContainerDb(kitchen_db, "Kitchen DB", "PostgreSQL", "Proyección tickets — DB-per-service")

        Container(delivery_svc, "Delivery Service", "Java / Spring Boot", "C-05 [FSD UC-03 UC-05]")
        ContainerDb(delivery_db, "Delivery DB", "PostgreSQL", "DB-per-service")

        Container(billing_svc, "Billing Service", "Java / Spring Boot", "C-06 [FSD UC-04] [NFR-10]")
        ContainerDb(billing_db, "Billing DB", "PostgreSQL", "DB-per-service")

        Container(notification_svc, "Notification Service", "Java / Spring Boot", "C-07 [PRD]")
        ContainerDb(notification_db, "Notification DB", "PostgreSQL", "DB-per-service")

        Container(monolito, "Monolito Legacy", "Java WAR", "Adaptador Strangler F0–F2 [ADR-0001]")
        ContainerDb(monolito_db, "Monolito DB", "PostgreSQL", "Esquema legacy")

        ContainerQueue(kafka, "Event Broker", "Apache Kafka", "order | payment | delivery | kitchen.commands [ADR-0002]")
    }

    System_Ext(stripe, "Stripe", "PSP [STK-06]")
    System_Ext(maps, "Google Maps", "Geo [STK-06]")
    System_Ext(notify_ext, "SendGrid / Twilio", "Notificaciones [STK-06]")

    Rel(consumidor, mobile_app, "Usa", "HTTPS")
    Rel(courier, mobile_app, "Usa", "HTTPS")
    Rel(restaurante, web_admin, "Gestiona cocina", "HTTPS")
    Rel(backoffice, web_admin, "Opera", "HTTPS")

    Rel(mobile_app, gateway, "APIs", "HTTPS/JSON")
    Rel(web_admin, gateway, "APIs", "HTTPS/JSON")

    Rel(gateway, consumer_svc, "Consumer API", "HTTPS/REST")
    Rel(gateway, restaurant_svc, "Restaurant API", "HTTPS/REST")
    Rel(gateway, order_svc, "Order API UC-01", "HTTPS/REST")
    Rel(gateway, kitchen_svc, "Kitchen API UC-02", "HTTPS/REST")
    Rel(gateway, delivery_svc, "Delivery API UC-03 UC-05", "HTTPS/REST")
    Rel(gateway, billing_svc, "Billing API UC-04", "HTTPS/REST")
    Rel(gateway, monolito, "Rutas legacy Strangler", "HTTPS/REST")

    Rel(consumer_svc, consumer_db, "Persistencia", "JDBC/PostgreSQL")
    Rel(restaurant_svc, restaurant_db, "Persistencia", "JDBC/PostgreSQL")
    Rel(order_svc, order_db, "Persistencia Order", "JDBC/PostgreSQL")
    Rel(kitchen_svc, kitchen_db, "Persistencia proyección", "JDBC/PostgreSQL")
    Rel(delivery_svc, delivery_db, "Persistencia", "JDBC/PostgreSQL")
    Rel(billing_svc, billing_db, "Persistencia", "JDBC/PostgreSQL")
    Rel(notification_svc, notification_db, "Persistencia", "JDBC/PostgreSQL")
    Rel(monolito, monolito_db, "Persistencia legacy", "JDBC/PostgreSQL")

    Rel(order_svc, kafka, "Publica order.events", "Kafka")
    Rel(kitchen_svc, kafka, "Publica kitchen.commands", "Kafka")
    Rel(kitchen_svc, kafka, "Consume order.events", "Kafka")
    Rel(order_svc, kafka, "Consume kitchen.commands", "Kafka")
    Rel(order_svc, kafka, "Consume payment.events", "Kafka")
    Rel(order_svc, kafka, "Consume delivery.events", "Kafka")
    Rel(billing_svc, kafka, "Publica payment.events", "Kafka")
    Rel(monolito, kafka, "Publica payment.events", "Kafka")
    Rel(monolito, kafka, "Consume order.events", "Kafka")
    Rel(delivery_svc, kafka, "Consume order.events", "Kafka")
    Rel(delivery_svc, kafka, "Publica delivery.events", "Kafka")
    Rel(notification_svc, kafka, "Consume order.events", "Kafka")
    Rel(notification_svc, kafka, "Consume payment.events", "Kafka")
    Rel(notification_svc, kafka, "Consume delivery.events", "Kafka")

    Rel(billing_svc, stripe, "Cobro y reembolso", "HTTPS/REST")
    Rel(delivery_svc, maps, "Rutas y ETA", "HTTPS/REST")
    Rel(notification_svc, notify_ext, "Email SMS push", "HTTPS/REST")
